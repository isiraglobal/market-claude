rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Public read-only access (dashboard can read all market data) ──────────
    match /stocks/{symbol} {
      allow read: if true;
      allow write: if request.auth != null
                   || (request.headers.keys().hasAny(['authorization'])
                       && request.headers['authorization'].matches('Bearer .+'));
    }

    match /stockIndex/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /historicalData/{date}/stocks/{symbol} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /intradaySnapshots/{date}/metadata {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
